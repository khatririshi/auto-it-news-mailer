# .env.example
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env to version control.

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Get your free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Gmail settings ────────────────────────────────────────────────────────────
# The Gmail address you are sending FROM
SENDER_EMAIL=your_gmail_address@gmail.com

# Gmail App Password (NOT your regular password)
# How to generate one: https://support.google.com/accounts/answer/185833
# Steps: Google Account → Security → 2-Step Verification → App Passwords
SENDER_PASSWORD=your_16_char_gmail_app_password

# Who should receive the email (separate multiple with commas)
# Example: friend@example.com,colleague@example.com
RECIPIENT_EMAIL=recipient@example.com
